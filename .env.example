# Скопируйте в .env.local для разработки.
# Основной админ (полный доступ, вне таблицы сотрудников):
ADMIN_LOGIN=admin
ADMIN_PASSWORD=changeme
# Устаревший вход только по паролю (без логина) — тот же ADMIN_PASSWORD
ADMIN_SESSION_SECRET=local-dev-jwt-secret-min-16-chars-ok

# SMS.ru: уведомления мастерам и (опционально) клиентам при смене статуса записи
# SMS_API_ID=
# Имя отправителя из кабинета SMS.ru (раздел «Отправители») — без этого часто отклоняют отправку
# SMS_FROM=
# 1 — отправлять клиенту SMS при статусе «Подтверждено» / «Отменено» в админке
# SMS_NOTIFY_CLIENT_STATUS=0

# SMTP для рассылки клиентам из базы (раздел «База клиентов»)
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Barbershop <noreply@example.com>
